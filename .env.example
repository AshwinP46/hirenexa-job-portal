# ─────────────────────────────────────────────────────────────
# HireNexa — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Client-side (Vite exposes VITE_* vars to the browser bundle)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# Server-side (SSR / Nitro — same values as above)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# Server-only admin key — bypasses RLS. NEVER expose to the client.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"
